bind 0 nxt : {v:func(1, [bool, bool]) | true }
bind 1 hd  : {v:func(1, [bool, bool]) | true}
bind 2 globally : {v:func(1, [bool, bool]) | true}
bind 3 m  : {v:func(1, [bool, bool]) | true}
bind 99 Down : {v:bool | true}
bind 100 Up : {v:bool | true}
bind 101 dt : {v:real | ( ((tmp_1 =  (((v > 0.0) && (v = 0.1))))) && (((v > 0.0) && (v = 0.1)) && nxt (globally tmp_1)))}
bind 102 flow : {v:real | ( ((tmp_7 =  (((v = maxflow) || (v = 0.0))))) && ((v = 0.0) && nxt (globally tmp_7)))}
bind 103 last_flow : {v:real | ((v = maxflow) || (v = 0.0))}
bind 104 last_level : {v:real | ((v >= minlevel) && (v <= maxlevel))}
bind 105 level : {v:real | ( ((tmp_8 =  (((v >= minlevel) && (v <= maxlevel))))) && ((v = 15.0) && nxt (globally tmp_8)))}
bind 106 maxflow : {v:real | ( ((tmp_2 =  (((v > 0.0) && (v = 0.5))))) && (((v > 0.0) && (v = 0.5)) && nxt (globally tmp_2)))}
bind 107 maxlevel : {v:real | ( ((tmp_5 =  ((((v > minlevel) && (v > 15.0)) && (v = 16.5))))) && ((((v > minlevel) && (v > 15.0)) && (v = 16.5)) && nxt (globally tmp_5)))}
bind 108 minlevel : {v:real | ( ((tmp_4 =  ((((v > 0) && (v < 15)) && (v = 14.5))))) && ((((v > 0) && (v < 15)) && (v = 14.5)) && nxt (globally tmp_4)))}
bind 109 mode : {v:bool | ((v = Down) || (v = Up))}
bind 110 mode_last : {v:bool | ((v = Down) || (v = Up))}
bind 111 outflow : {v:real | ( ((tmp_3 =  (((v > 0.0) && (v = 0.1))))) && (((v > 0.0) && (v = 0.1)) && nxt (globally tmp_3)))}
bind 112 tmp_1 : {v:bool | true}
bind 113 tmp_2 : {v:bool | true}
bind 114 tmp_3 : {v:bool | true}
bind 115 tmp_4 : {v:bool | true}
bind 116 tmp_5 : {v:bool | true}
bind 117 tmp_6 : {v:bool | true}
bind 118 tmp_7 : {v:bool | true}
bind 119 tmp_8 : {v:bool | true}

constraint:
  env [0;1;2;3;99;100;101;102;103;104;105;106;107;108;109;110;111;112;113;114;115;116;117;118;119]
  lhs {v:real | (((( (not ((last_level >= (maxlevel - 0.5))))) && (v = maxflow)))) || (((true && (last_level >= (maxlevel - 0.5)))) && (v = 0.0)) || (((((not ((last_level <= (minlevel + 0.5))))) && (v = 0.0)))) || ((((true && (last_level <= (minlevel + 0.5)))) && (v = maxflow)))}
  rhs {v:real | ((v = maxflow) || (v = 0.0))}
  id 5 tag []