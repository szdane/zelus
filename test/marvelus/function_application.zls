(* This is a test file for the refinement function application unit tests  *) 


let incr (x : {v:float|v>0.0} ) : { v:float | v > x } =
  x +. 1.0

let add (x : {v:float | v > 0.0}) (y : {v:float|v > 0.0}) : { v : float | v >=x && v >= y} =
  x +. y

let node main () =
    let w = (incr (2.0)) in         (* pass *)
    let z = (add (2.0) (3.0)) in    (* pass *)
    let w2 = (incr (-.1.0)) in      (* fail *)
    let w3 = (add (2.0) (-3.0)) in  (* fail *)
  ()



