bind 0 nxt : {v:func(1, [bool, bool]) | true }
bind 1 hd  : {v:func(1, [bool, bool]) | true}
bind 2 globally : {v:func(1, [bool, bool]) | true}
bind 3 m  : {v:func(1, [bool, bool]) | true}
bind 8 last_temp : {v:Int | ( ((tmp_1 =  ((v <= 0)))) && tmp_1)}
bind 9 temp : {v:Int | ( ((tmp_2 =  ((v <= 0)))) && ((v <= 0) && nxt (globally (m tmp_2))))}
bind 10 tmp_1 : {v:bool | true}
bind 11 tmp_2 : {v:bool | true}

constraint:
  env [0;1;2;3;8;9;10;11]
  lhs {v:Int | (v = (last_temp - 1))}
  rhs {v:Int | (v <= 0)}
  id 5 tag []