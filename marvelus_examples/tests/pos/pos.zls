(* ==== POS 1: NF on constants; strip X(G(..)) vs X(true) ==== *)
let five  : {v:int | v = 5 && x(g(v = 5))} = 2+3-0
let five' : {v:int | v = 5 && x(true)}    = 5         

(* ==== POS 2: ITE (constdecl) guarded heads with NF ==== *)
let foo : {v:int | v >= 0 && x(g(v >= 0))} = 3
let ite_ok : {v:int | g(v <= 0)} =
  if foo >= 0 then -1*foo else foo
(* THEN: foo≥0 ⇒ -foo≤0; ELSE: ¬(foo≥0) ⇒ foo≤0 (vacuous or true) *)

(* ==== POS 3: ITE inside let (node body); per-branch checks ==== *)
let node ite_let_ok () : {(v:int) | g(v <= 0)} =
  let (foo : {v:int | v >= 0 && x(g(v >= 0))}) = 2 in
  let (z   : {v:int | v <= 0}) =
    if foo >= 0 then -1*foo else foo in
  z

(* ==== POS 4: FBY in return; synthesized head/tail matches ==== *)
let node hold_first_then (a:{(v:int)| true}) : {(v:int) | v = 0 && x(g(m(v = a)))} =
  0 fby a
(* LHS NF ~ v=0 && X(G(M(v=a))) exactly matches the spec *)

(* ==== POS 5: Boolean ops with fby; ==== *)
let b:{v:bool | g(v = true)} = true
let node edge b:{(v:bool) | v=false && x(g(m(v=true)))} = (false fby b)


(* ==== POS 6: “tmp” style rewrite tolerance in env ==== *)
let ok_tmp : {v:int | v >= 0 && x(g(v >= 0))} = 7
let pin   : {v:int | x(g(v = ok_tmp))}       = ok_tmp

let dt = 0.1 
let a = 5

let hybrid main () = let rec trigger = (period (dt)) in
        present (trigger) -> (let (x) = pin in
        (print_int x; print_newline ())) else ()
