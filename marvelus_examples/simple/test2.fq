bind 0 x : {v:func(1, [bool, bool]) | (i => j) => ((x i)=> (x j)) }
bind 1 hd  : {v:func(1, [bool, bool]) | true}
bind 2 g : {v:func(1, [bool, bool]) | (i => j) => (((g i)=> (g j)) && ((g i)=> (x j)) && ((g i)=> (m j)))}
bind 3 m  : {v:func(1, [bool, bool]) | (i => j) => ((m i)=> (m j))}
bind 4 i : {v: bool | true} 
bind 5 j : {v: bool | true} 
bind 134 dt : {v:real |  (tmp_1 =  (v > 0.0 && v = 0.1)) && v > 0.0 && v = 0.1 && x (g tmp_1)}
bind 135 flow : {v:real |  (tmp_6 =  ( (not (last_level >= maxlevel - 0.5) && v = maxflow) ||  (not (last_level <= minlevel + 0.5) && v = 0.0))) &&  ( (not (last_level >= maxlevel - 0.5) && v = maxflow) ||  (not (last_level <= minlevel + 0.5) && v = 0.0)) && x (g tmp_6)}
bind 136 last_flow : {v:real | v = maxflow || v = 0.0 && x true}
bind 137 last_level : {v:real | v >= minlevel && v <= maxlevel && v <= maxlevel - dt * (maxflow - outflow) && last_flow = maxflow || v >= minlevel + dt * outflow && last_flow = 0.0 && x true}
bind 138 level : {v:real | v = last_level + last_flow - outflow * dt && x true}
bind 139 maxflow : {v:real |  (tmp_2 =  (v > 0.0 && v = 0.5)) && v > 0.0 && v = 0.5 && x (g tmp_2)}
bind 140 maxlevel : {v:real |  (tmp_5 =  (v > minlevel && v > 15.0 && v = 16.5)) && v > minlevel && v > 15.0 && v = 16.5 && x (g tmp_5)}
bind 141 minlevel : {v:real |  (tmp_4 =  (v > 0 && v < 15 && v = 14.5)) && v > 0 && v < 15 && v = 14.5 && x (g tmp_4)}
bind 142 outflow : {v:real |  (tmp_3 =  (v > 0.0 && v = 0.1)) && v > 0.0 && v = 0.1 && x (g tmp_3)}
bind 143 tmp_1 : {v:bool | true}
bind 144 tmp_2 : {v:bool | true}
bind 145 tmp_3 : {v:bool | true}
bind 146 tmp_4 : {v:bool | true}
bind 147 tmp_5 : {v:bool | true}
bind 148 tmp_6 : {v:bool | true}

constraint:
  env [0;1;2;3;4;5;134;135;136;137;138;139;140;141;142;143;144;145;146;147;148]
  lhs {v:real |  ( (not (last_level >= maxlevel - 0.5) && v = last_level + last_flow - outflow * dt) ||  (not (last_level <= minlevel + 0.5) && v = last_level + last_flow - outflow * dt))}
  rhs {v:real | v >= minlevel && v <= maxlevel && ((v <= maxlevel - dt * (maxflow - outflow) && last_flow = maxflow) || (v >= minlevel + dt * outflow && last_flow = 0.0))}
  id 5 tag []