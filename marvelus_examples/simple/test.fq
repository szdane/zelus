bind 0 x : {v:func(1, [bool, bool]) | (i => j) => ((x i)=> (x j)) }
bind 1 hd  : {v:func(1, [bool, bool]) | true}
bind 2 g : {v:func(1, [bool, bool]) | (i => j) => (((g i)=> (g j)) && ((g i)=> (x j)) && ((g i)=> (m j)))}
bind 3 m  : {v:func(1, [bool, bool]) | (i => j) => ((m i)=> (m j))}
bind 4 i : {v: bool | true} 
bind 5 j : {v: bool | true} 
bind 92 dt : {v:real |  (tmp_1 =  (v > 0.0 && v = 0.1)) && v > 0.0 && v = 0.1 && x (g tmp_1)}
bind 96 last_flow : {v:real | v = maxflow || v = 0.0}
bind 97 last_level : {v:real | v >= minlevel && v <= maxlevel}
bind 98 level : {v:real | vf = 0.0 && vl = last_level + (last_flow - outflow) * dt && x true}
bind 93 f : {v:real | f = 0.0}

bind 94 flow : {v:real | vf = 0.0 && vl = last_level + last_flow - outflow * dt && x true}

bind 95 l : {v:real | l = 15.0}
bind 99 maxflow : {v:real |  (tmp_2 =  (v > 0.0 && v = 0.5)) && v > 0.0 && v = 0.5 && x (g tmp_2)}
bind 100 maxlevel : {v:real |  (tmp_5 =  (v > minlevel && v > 15.0 && v = 16.5)) && v > minlevel && v > 15.0 && v = 16.5 && x (g tmp_5)}
bind 101 minlevel : {v:real |  (tmp_4 =  (v > 0 && v < 15 && v = 14.5)) && v > 0 && v < 15 && v = 14.5 && x (g tmp_4)}
bind 102 outflow : {v:real |  (tmp_3 =  (v > 0.0 && v = 0.1)) && v > 0.0 && v = 0.1 && x (g tmp_3)}
bind 103 tmp_1 : {v:bool | true}
bind 104 tmp_2 : {v:bool | true}
bind 105 tmp_3 : {v:bool | true}
bind 106 tmp_4 : {v:bool | true}
bind 107 tmp_5 : {v:bool | true}
bind 108 vf : {v:real | v = 0.0}
bind 109 vl : {v:real | v = last_level + (last_flow - outflow) * dt}

constraint:
  env [0;1;2;3;4;5;92;93;94;95;96;97;98;99;100;101;102;103;104;105;106;107;108;109]
  lhs {vl:real |  ( (not (last_level >= maxlevel - 0.5) && 
  vf = maxflow && 
  vl = last_level + (vf - outflow) * dt) 
  ||  
  (not (last_level <= minlevel + 0.5) && 
  vf = 0.0 && 
  vl = last_level + (vf - outflow) * dt))}

  rhs {vl:real | vl >= minlevel && vl <= maxlevel && (
    (vl <= maxlevel - dt * (maxflow - outflow) && vf = maxflow) 
    || 
    (vl >= minlevel + dt * outflow && vf = 0.0)
    )}
  id 5 tag []