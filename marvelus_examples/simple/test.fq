bind 0 x : {v:func(1, [bool, bool]) | (i => j) => ((x i)=> (x j)) }
bind 1 hd  : {v:func(1, [bool, bool]) | true}
bind 2 g : {v:func(1, [bool, bool]) | (i => j) => (((g i)=> (g j)) && ((g i)=> (x j)) && ((g i)=> (m j)))}
bind 3 m  : {v:func(1, [bool, bool]) | (i => j) => ((m i)=> (m j))}
bind 4 i : {v: bool | true} 
bind 5 j : {v: bool | true} 
bind 10 ex : {v:Int |  (tmp_2 =  (v = last_ex + 1)) && v = last_ex + 1 && x (g tmp_2)}
bind 11 last_ex : {v:Int |  (tmp_1 =  (v > 0 && v < 5)) && v > 0 && v < 5 && x (g tmp_1)}
bind 12 tmp_1 : {v:bool | true}
bind 13 tmp_2 : {v:bool | true}

constraint:
  env [0;1;2;3;4;5;10;11;12;13]
  lhs {v:Int | v = stupid}
  rhs {v:Int | v = stupid}
  id 5 tag []