bind 0 nxt : {v:func(1, [bool, bool]) | true }
bind 1 hd  : {v:func(1, [bool, bool]) | true}
bind 2 globally : {v:func(1, [bool, bool]) | true}
bind 3 m  : {v:func(1, [bool, bool]) | true}
bind 8 last_last_x : {v:Int | true}
bind 9 last_x : {v:Int | true}

constraint:
  env [0;1;2;3;8;9]
  lhs {v:Int | (((last_x > 5) && (v = 1)) || ( (not ((last_x > 5))) && (v = (last_last_x + 1))))}
  rhs {v:Int |(v <= 6)}
  id 5 tag []