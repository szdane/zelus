    and automaton_ref : {last_x : {v:int | globally(v>0 && v<5)}}
    | Up : {x:{v:int | globally(v = (last x) + 1)}} -> do x = (last x) + 1 unless ((last x) >= 4) then Down
    | Down : {x:{v:int | globally(v = (last x) - 1)}} -> do x = (last x) - 1 unless ((last x) <= 1) then Up
    end : {x:{v:int | globally(v>0 && v <5)}} in x*)
