let node test_reset () : {v: int | true} = 
    init x = 0
    and automaton
    | A1 -> x = 0 fby (x+1) unless (last x > 5) then A2
    | A2 -> x = 2 fby (x-2) unless (last x < -10) then A1
    end in x

let dt = 0.1
let hybrid main () = 
    let rec trigger = (period (dt)) in
        present (trigger) -> (let x = test_reset () in
        (print_int x; print_newline ())) else ()